PORT=5001
HOST=0.0.0.0
GEMINI_MODEL=gemini-2.5-flash

# Use either a comma-separated list...
GEMINI_API_KEYS=your-first-key,your-second-key

# ...or indexed keys.
# GEMINI_API_KEY_1=your-first-key
# GEMINI_API_KEY_2=your-second-key

# Optional fallback for a single shared key.
# GEMINI_API_KEY=your-only-key

# Optional tuning
# GEMINI_KEY_COOLDOWN_MS=60000
# REQUEST_BODY_LIMIT=10mb
